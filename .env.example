# ---- AI ----
AI_MODE=hybrid
AI_MODEL=gpt-4.1-mini
AI_ENDPOINT=responses
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-REPLACE_ME
AI_FALLBACK_ENABLED=1

# ---- Audio / IMU ----
AUDIO_BACKEND=arecord
IMU_TRANSPORT=udp
IMU_UDP_HOST=0.0.0.0
IMU_UDP_PORT=9001

# ---- Session ----
SESSION_ENABLED=1
SESSION_REQUIRE_START_EVENT=1
SESSION_AUTO_STOP_SEC=10
SESSION_MIN_DURATION_SEC=1.0
SESSION_COOLDOWN_SEC=0.8
SESSION_ARCHIVE_ENABLED=1
SESSION_ARCHIVE_DIR=sessions

# ---- Printer (Jetson direct CUPS) ----
PRINTER_TRANSPORT=cups
PRINTER_CUPS_PRINTER=star
PRINTER_CUPS_MODE=image
PRINTER_CUPS_ORIENTATION=portrait
PRINTER_CUPS_LAYOUT=horizontal
PRINTER_QR_URL=https://www.yahoo.co.jp/
PRINTER_SHRINE_NAME=ぬるみゃく神社

# ---- Dashboard ----
WEB_DASHBOARD_ENABLED=1
WEB_DASHBOARD_HOST=0.0.0.0
WEB_DASHBOARD_PORT=5000
